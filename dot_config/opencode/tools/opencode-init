#!/usr/bin/env bash
set -euo pipefail

# opencode-init — Bootstrap a new project from an archetype
#
# This script owns all generation logic. It is called by the OpenCode init
# command or can be run independently. No generation logic lives in prompts
# or agents.
#
# Usage:
#   opencode-init --list-archetypes [--json]
#   opencode-init --list-components <archetype> [--json]
#   opencode-init <archetype> [options]

# --- Configuration ---
TEMPLATE_DIR="${TEMPLATE_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/opencode/templates}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- Helpers ---
usage() {
    cat <<EOF
Usage: $(basename "$0") <command> [options]

Commands:
  --list-archetypes              List available archetypes
  --list-components <archetype>  List available components for an archetype
  <archetype>                    Generate project from archetype

Options:
  --components <list>    Comma-separated component names
  --output <dir>         Target directory (default: cwd)
  --dry-run              Preview only, no files written
  --force                Overwrite existing files
  --merge                Smart merge with existing files
  --skip-existing        Skip files that already exist
  --json                 Machine-readable output
  -h, --help             Show this help message
EOF
    exit 0
}

die() {
    echo "Error: $*" >&2
    exit 1
}

warn() {
    echo "Warning: $*" >&2
}

# --- YAML parsing (minimal, no deps) ---
yaml_get() {
    local file="$1"
    local key="$2"
    grep -E "^${key}:" "$file" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//' | sed 's/^"//;s/"$//'
}

yaml_get_array() {
    local file="$1"
    local key="$2"
    sed -n "/^${key}:/,/^[^ ]/p" "$file" 2>/dev/null | grep -E "^\s+- " | sed 's/^\s*-\s*//'
}

yaml_get_nested_array() {
    local file="$1"
    local parent="$2"
    local child="$3"
    awk -v parent="$parent" -v child="$child" '
    $0 ~ "^"parent":" { in_parent=1; next }
    in_parent && $0 ~ "^  "child":" { in_child=1; next }
    in_child && /^    - / { print substr($0, index($0, "- ") + 2); next }
    in_child && /^  [a-z]/ && $0 !~ "^    " { in_child=0; in_parent=0; next }
    in_parent && /^[a-z]/ && $0 !~ "^  " { in_parent=0 }
    ' "$file"
}

# --- Validation ---
validate_manifest() {
    local manifest="$1/manifest.yaml"
    [[ -f "$manifest" ]] || die "Template manifest not found at $manifest"
    local sv
    sv=$(yaml_get "$manifest" "schema_version")
    [[ -n "$sv" ]] || die "manifest.yaml missing schema_version"
    local max_sv=1
    (( sv >= 1 && sv <= max_sv )) || die "Schema version $sv not supported (max: $max_sv)"
}

validate_archetype_yaml() {
    local file="$1"
    [[ -f "$file" ]] || die "Archetype definition not found: $file"
    local sv
    sv=$(yaml_get "$file" "schema_version")
    [[ -n "$sv" ]] || die "$file missing schema_version"
    local name
    name=$(yaml_get "$file" "name")
    [[ -n "$name" ]] || die "$file missing name"
}

archetype_extends() {
    local archetype_dir="$1"
    local yaml_file="$archetype_dir/archetype.yaml"
    [[ -f "$yaml_file" ]] && yaml_get "$yaml_file" "extends" || true
}

resolve_inheritance() {
    local archetype="$1"
    local -a chain=()
    local current="$archetype"
    local -a seen=()

    while [[ -n "$current" ]]; do
        for s in "${seen[@]}"; do
            if [[ "$s" == "$current" ]]; then
                local chain_str
                chain_str=$(IFS='→ '; echo "${seen[*]}")
                die "Circular inheritance detected: $chain_str→ $current"
            fi
        done
        seen+=("$current")
        chain+=("$current")

        local dir="$TEMPLATE_DIR/archetypes/$current"
        if [[ ! -d "$dir" ]]; then
            die "Archetype '$current' not found (extends chain: ${seen[*]})"
        fi

        current=$(archetype_extends "$dir" || true)
    done

    local -a reversed=()
    for (( i=${#chain[@]}-1; i>=0; i-- )); do
        reversed+=("${chain[$i]}")
    done
    echo "${reversed[@]}"
}

# --- Discovery ---
list_archetypes() {
    local json="$1"
    local -a archetypes=()
    for dir in "$TEMPLATE_DIR/archetypes/"*/; do
        [[ -d "$dir" ]] || continue
        local name
        name=$(basename "$dir")
        archetypes+=("$name")
    done

    if [[ "$json" == "true" ]]; then
        local first=true
        echo -n '{"archetypes":['
        for a in "${archetypes[@]}"; do
            $first || echo -n ","
            first=false
            echo -n "\"$a\""
        done
        echo ']}'
    else
        printf '%s\n' "${archetypes[@]}"
    fi
}

list_components() {
    local archetype="$1"
    local json="$2"

    local dir="$TEMPLATE_DIR/archetypes/$archetype"
    [[ -d "$dir" ]] || die "Archetype '$archetype' not found"

    local yaml_file="$dir/archetype.yaml"
    [[ -f "$yaml_file" ]] || die "Archetype definition not found: $yaml_file"

    local -a components=()
    while IFS= read -r comp; do
        [[ -n "$comp" ]] && components+=("$comp")
    done < <(yaml_get_nested_array "$yaml_file" "components" "optional")

    if [[ "$json" == "true" ]]; then
        local first=true
        echo -n '{"components":['
        for c in "${components[@]}"; do
            $first || echo -n ","
            first=false
            echo -n "\"$c\""
        done
        echo ']}'
    else
        printf '%s\n' "${components[@]}"
    fi
}

# --- Validation helpers ---
validate_components() {
    local -a components=("$@")
    for comp in "${components[@]}"; do
        local comp_dir="$TEMPLATE_DIR/components/$comp"
        [[ -d "$comp_dir" ]] || die "Component '$comp' not found in templates/components/"
        [[ -f "$comp_dir/component.yaml" ]] || die "Component '$comp' missing component.yaml"
    done
}

validate_workflows() {
    local -a workflows=("$@")
    for wf in "${workflows[@]}"; do
        [[ -f "$TEMPLATE_DIR/workflows/$wf.md" ]] || die "Workflow '$wf' not found in templates/workflows/"
    done
}

validate_skills() {
    local mode="$1"
    shift
    local -a skills=("$@")
    local global_skills_dir="${XDG_CONFIG_HOME:-$HOME/.config}/opencode/skills"
    local template_skills_dir="$TEMPLATE_DIR/skills"

    [[ ${#skills[@]} -eq 0 ]] && return 0

    for sk in "${skills[@]}"; do
        local found=false
        # Check global skills
        if [[ -d "$global_skills_dir/$sk" || -f "$global_skills_dir/$sk/SKILL.md" ]]; then
            found=true
        fi
        # Also check .opencode/skills fallback
        if [[ "$found" == "false" && -d "$template_skills_dir/$sk" ]]; then
            found=true
        fi

        if [[ "$found" == "false" ]]; then
            if [[ "$mode" == "required" ]]; then
                warn "Required skill '$sk' not found in $global_skills_dir (install before using)"
            else
                warn "Recommended skill '$sk' not available in $global_skills_dir"
            fi
        fi
    done
}

# --- Generation ---
generate_scaffold() {
    local archetype="$1"
    local output_dir="$2"
    local dry_run="${3:-false}"
    local mode="${4:-}"
    shift 4
    local -a selected_components=("$@")

    if [[ -d "$output_dir/.opencode" && -z "$mode" ]]; then
        die "Directory '$output_dir' already has a .opencode directory. Use --force, --merge, or --skip-existing."
    fi

    # Resolve inheritance chain
    local -a chain=()
    while IFS=' ' read -r -a arr; do
        chain=("${arr[@]}")
    done < <(resolve_inheritance "$archetype")

    # Collect all workflows from chain
    local -A all_wfs=()
    for arch in "${chain[@]}"; do
        local arch_yaml="$TEMPLATE_DIR/archetypes/$arch/archetype.yaml"
        [[ -f "$arch_yaml" ]] || continue
        while IFS= read -r wf; do
            [[ -n "$wf" ]] && all_wfs["$wf"]=1
        done < <(yaml_get_array "$arch_yaml" "required_workflows"; yaml_get_array "$arch_yaml" "optional_workflows")
    done

    # Add component workflows
    for comp in "${selected_components[@]}"; do
        local comp_file="$TEMPLATE_DIR/components/$comp/component.yaml"
        [[ -f "$comp_file" ]] || continue
        while IFS= read -r wf; do
            [[ -n "$wf" ]] && all_wfs["$wf"]=1
        done < <(yaml_get_array "$comp_file" "workflows")
    done

    # Dry run output
    if [[ "$dry_run" == "true" ]]; then
        echo "=== Dry Run ==="
        echo "Archetype: $archetype"
        echo "Inheritance: ${chain[*]}"
        echo "Components: ${selected_components[*]:-(none)}"
        echo "Output: $output_dir"
        echo ""
        echo "Files:"
        echo "  .opencode/project.md"
        echo "  .opencode/stack.md"
        echo "  .opencode/.generated.yaml"
        echo "  .opencode/README.md"
        echo ""
        echo "Workflows:"
        for wf in "${!all_wfs[@]}"; do
            echo "  - $wf"
        done
        echo ""
        echo "Stack sections:"
        for comp in "${selected_components[@]}"; do
            local comp_file="$TEMPLATE_DIR/components/$comp/component.yaml"
            [[ -f "$comp_file" ]] || continue
            while IFS= read -r section; do
                [[ -n "$section" ]] && echo "  - $section (from $comp)"
            done < <(yaml_get_nested_array "$comp_file" "adds" "stack_sections")
        done
        if [[ "$json" == "true" ]]; then
            # Build JSON output
            echo -n '{"dry_run":true,"archetype":"'
            echo -n "$archetype"
            echo -n '","components":['
            local firstc=true
            for c in "${selected_components[@]}"; do
                $firstc || echo -n ","
                firstc=false
                echo -n "\"$c\""
            done
            echo -n '],"workflows":['
            local firstw=true
            for wf in "${!all_wfs[@]}"; do
                $firstw || echo -n ","
                firstw=false
                echo -n "\"$wf\""
            done
            echo ']}'
        fi
        return 0
    fi

    # Create .opencode directory
    mkdir -p "$output_dir/.opencode/workflows"

    # Check for existing files
    local has_existing=false
    for f in project.md stack.md .generated.yaml README.md; do
        [[ -f "$output_dir/.opencode/$f" ]] && has_existing=true
    done

    if [[ "$has_existing" == "true" ]]; then
        case "$mode" in
            force)
                warn "Overwriting existing files (--force)"
                ;;
            merge)
                warn "Merging with existing files (--merge)"
                ;;
            skip-existing)
                warn "Skipping existing files (--skip-existing)"
                for f in project.md stack.md .generated.yaml README.md; do
                    if [[ -f "$output_dir/.opencode/$f" ]]; then
                        echo "  Skip: $f (already exists)"
                    fi
                done
                for wf in "$TEMPLATE_DIR/workflows/"*.md; do
                    local wf_name
                    wf_name=$(basename "$wf")
                    if [[ -f "$output_dir/.opencode/workflows/$wf_name" ]]; then
                        echo "  Skip: workflows/$wf_name (already exists)"
                    fi
                done
                ;;
        esac
    fi

    # Generate project.md
    local project_md="$output_dir/.opencode/project.md"
    if [[ ! -f "$project_md" || "$mode" == "force" || "$mode" == "merge" ]]; then
        if [[ -f "$TEMPLATE_DIR/project.md.tmpl" ]]; then
            local content
            content=$(<"$TEMPLATE_DIR/project.md.tmpl")
            content="${content//'{{ project_name }}'/$archetype-project}"
            printf '%s\n' "$content" > "$project_md"
            echo "  Create: project.md"
        fi
    fi

    # Generate stack.md
    local stack_md="$output_dir/.opencode/stack.md"
    if [[ ! -f "$stack_md" || "$mode" == "force" || "$mode" == "merge" ]]; then
        if [[ -f "$TEMPLATE_DIR/stack.md.tmpl" ]]; then
            cp "$TEMPLATE_DIR/stack.md.tmpl" "$stack_md"
            echo "  Create: stack.md"
        fi
    fi

    # Append component stack sections
    for comp in "${selected_components[@]}"; do
        # Skip if stack.md exists and mode is skip-existing
        if [[ "$mode" == "skip-existing" && -f "$stack_md" ]]; then
            echo "  Skip: $comp stack sections (stack.md unchanged)"
            continue
        fi
        local comp_stack="$TEMPLATE_DIR/components/$comp/stack.md.tmpl"
        if [[ -f "$comp_stack" ]]; then
            echo "" >> "$stack_md"
            cat "$comp_stack" >> "$stack_md"
            echo "  Append: $comp stack sections to stack.md"
        fi
    done

    # Copy workflow files
    for wf in "${!all_wfs[@]}"; do
        local src="$TEMPLATE_DIR/workflows/$wf.md"
        local dst="$output_dir/.opencode/workflows/$wf.md"
        if [[ ! -f "$dst" ]]; then
            if [[ -f "$src" ]]; then
                cp "$src" "$dst"
                echo "  Copy: workflows/$wf.md"
            fi
        elif [[ "$mode" == "force" ]]; then
            if [[ -f "$src" ]]; then
                cp "$src" "$dst"
                echo "  Overwrite: workflows/$wf.md"
            fi
        elif [[ "$mode" == "merge" ]]; then
            if [[ -f "$src" ]]; then
                if diff -q "$src" "$dst" &>/dev/null; then
                    echo "  Same: workflows/$wf.md (skipped)"
                else
                    cp "$src" "$dst"
                    echo "  Update: workflows/$wf.md (merged, diff shown above)"
                fi
            fi
        elif [[ "$mode" == "skip-existing" ]]; then
            if [[ -f "$dst" ]]; then
                echo "  Skip: workflows/$wf.md (already exists)"
            elif [[ -f "$src" ]]; then
                cp "$src" "$dst"
                echo "  Copy: workflows/$wf.md"
            fi
        else
            if [[ -f "$src" ]]; then
                cp "$src" "$dst"
                echo "  Copy: workflows/$wf.md"
            fi
        fi
    done

    # Create README.md
    local readme="$output_dir/.opencode/README.md"
    if [[ ! -f "$readme" || "$mode" == "force" ]]; then
        cat > "$readme" << 'README_EOF'
# Project Layer

This directory contains project-level context, stack documentation, and
reusable workflows for this repository.

## Contents

| File / Directory | Purpose |
|------------------|---------|
| `project.md` | Project identity — purpose, goals, constraints, priorities, success metrics, non-goals |
| `stack.md` | Technology stack — backend, frontend, database, infrastructure, CI/CD, observability, and architecture decision records |
| `workflows/` | Executable process definitions — feature development, bug fixes, deployment, architecture review, incident response |
README_EOF
        echo "  Create: README.md"
    fi

    # Generate .generated.yaml
    local gen_yaml="$output_dir/.opencode/.generated.yaml"
    local manifest="$TEMPLATE_DIR/manifest.yaml"
    local manifest_hash=""
    if [[ -f "$manifest" ]]; then
        manifest_hash=$(sha256sum "$manifest" | cut -d' ' -f1)
    fi

    cat > "$gen_yaml" << YAML_EOF
schema_version: 1
migration_version: 1
generator_version: 1
template_version: $(yaml_get "$manifest" "template_version" 2>/dev/null || echo "1")
template_manifest_hash: "${manifest_hash}"
archetype: ${archetype}
inheritance_chain:
YAML_EOF
    for arch in "${chain[@]}"; do
        echo "  - ${arch}" >> "$gen_yaml"
    done

    cat >> "$gen_yaml" << YAML_EOF
components:
YAML_EOF
    for comp in "${selected_components[@]}"; do
        echo "  - ${comp}" >> "$gen_yaml"
    done

    echo "generated_at: \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"" >> "$gen_yaml"
    echo "  Create: .generated.yaml"

    echo ""
    echo "Scaffold generated at: $output_dir/.opencode/"
}

# --- Main ---
main() {
    [[ $# -eq 0 ]] && usage

    local archetype=""
    local components=""
    local output_dir="."
    local dry_run="false"
    local json="false"
    local mode=""

    case "${1:-}" in
        --list-archetypes)
            json="false"
            [[ "${2:-}" == "--json" ]] && json="true"
            list_archetypes "$json"
            exit 0
            ;;
        --list-components)
            [[ -z "${2:-}" ]] && die "Usage: $(basename "$0") --list-components <archetype>"
            archetype="$2"
            json="false"
            [[ "${3:-}" == "--json" ]] && json="true"
            list_components "$archetype" "$json"
            exit 0
            ;;
        -h|--help)
            usage
            ;;
        *)
            archetype="${1:-}"
            shift
            ;;
    esac

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --components)
                components="$2"
                shift 2
                ;;
            --output)
                output_dir="$2"
                shift 2
                ;;
            --dry-run)
                dry_run="true"
                shift
                ;;
            --force)
                mode="force"
                shift
                ;;
            --merge)
                mode="merge"
                shift
                ;;
            --skip-existing)
                mode="skip-existing"
                shift
                ;;
            --json)
                json="true"
                shift
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    [[ -z "$archetype" ]] && die "Archetype is required"

    local archetype_dir="$TEMPLATE_DIR/archetypes/$archetype"
    [[ -d "$archetype_dir" ]] || die "Archetype '$archetype' not found in $TEMPLATE_DIR/archetypes/"

    validate_manifest "$TEMPLATE_DIR"
    validate_archetype_yaml "$archetype_dir/archetype.yaml"

    local -a chain=()
    while IFS=' ' read -r -a arr; do
        chain=("${arr[@]}")
    done < <(resolve_inheritance "$archetype")
    echo "Inheritance: ${chain[*]}" >&2

    local -a selected_components=()
    if [[ -n "$components" ]]; then
        IFS=',' read -ra selected_components <<< "$components"
        for i in "${!selected_components[@]}"; do
            selected_components[$i]=$(echo "${selected_components[$i]}" | xargs)
        done
        validate_components "${selected_components[@]}"
    fi

    # Check for duplicate components
    local -A comp_seen=()
    for comp in "${selected_components[@]}"; do
        if [[ -n "${comp_seen[$comp]:-}" ]]; then
            die "Duplicate component: $comp"
        fi
        comp_seen["$comp"]=1
    done

    # Validate workflows
    local -A all_wfs=()
    for arch in "${chain[@]}"; do
        local arch_yaml="$TEMPLATE_DIR/archetypes/$arch/archetype.yaml"
        [[ -f "$arch_yaml" ]] || continue
        while IFS= read -r wf; do
            [[ -n "$wf" ]] && all_wfs["$wf"]=1
        done < <(yaml_get_array "$arch_yaml" "required_workflows"; yaml_get_array "$arch_yaml" "optional_workflows")
    done
    for comp in "${selected_components[@]}"; do
        local comp_file="$TEMPLATE_DIR/components/$comp/component.yaml"
        [[ -f "$comp_file" ]] || continue
        while IFS= read -r wf; do
            [[ -n "$wf" ]] && all_wfs["$wf"]=1
        done < <(yaml_get_array "$comp_file" "workflows")
    done
    validate_workflows "${!all_wfs[@]}"

    # Validate required skills
    local -A req_skills=()
    for arch in "${chain[@]}"; do
        local arch_yaml="$TEMPLATE_DIR/archetypes/$arch/archetype.yaml"
        [[ -f "$arch_yaml" ]] || continue
        while IFS= read -r sk; do
            [[ -n "$sk" ]] && req_skills["$sk"]=1
        done < <(yaml_get_array "$arch_yaml" "required_skills")
    done
    validate_skills "required" "${!req_skills[@]}"

    # Validate recommended skills
    local -A rec_skills=()
    for arch in "${chain[@]}"; do
        local arch_yaml="$TEMPLATE_DIR/archetypes/$arch/archetype.yaml"
        [[ -f "$arch_yaml" ]] || continue
        while IFS= read -r sk; do
            [[ -n "$sk" ]] && rec_skills["$sk"]=1
        done < <(yaml_get_array "$arch_yaml" "recommended_skills")
    done
    validate_skills "recommended" "${!rec_skills[@]}"

    generate_scaffold "$archetype" "$output_dir" "$dry_run" "$mode" "${selected_components[@]}"
}

main "$@"
