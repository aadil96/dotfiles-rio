# SSH Configuration
# This file manages SSH client connections

# Global settings
Host *
    # Send keepalive packets to prevent connection timeouts
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Disable X11 forwarding by default
    ForwardX11 no

    # Use SSH agent for authentication
    ForwardAgent yes

    # Compression for faster transfers
    Compression yes

    # Connection settings
    ConnectTimeout 30
    ConnectionAttempts 3

# Example host configurations
# Uncomment and modify as needed

# GitHub
Host github.com
    HostName github.com
    User git
    IdentityFile {{ .ssh_key_path | default "~/.ssh/id_ed25519" }}
    IdentitiesOnly yes

# GitLab
Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile {{ .ssh_key_path | default "~/.ssh/id_ed25519" }}
    IdentitiesOnly yes