{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./AGENTS.md",
    "./docs/troubleshooting.md"
  ],
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git config --get*": "allow",
      "git rev-parse*": "allow",
      "git checkout main": "deny",
      "git checkout master": "deny",
      "git checkout -b * main": "deny",
      "git checkout -b * master": "deny",
      "git switch main": "deny",
      "git switch master": "deny",
      "git merge * main": "deny",
      "git merge * master": "deny",
      "git rebase * main": "deny",
      "git rebase * master": "deny",
      "git commit * main": "deny",
      "git commit * master": "deny",
      "git push * main": "deny",
      "git push * master": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git push --force-with-lease*": "deny",
      "git reset --hard*": "deny",
      "git clean -fd*": "deny",
      "git reflog expire*": "deny",
      "git filter-branch*": "deny",
      "git filter-repo*": "deny",
      "git add *": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git fetch*": "allow",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git stash*": "ask",
      "ls*": "allow",
      "cat *": "allow",
      "grep*": "allow",
      "find*": "allow",
      "pwd": "allow",
      "echo*": "allow",
      "which*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "rm -rf*": "deny",
      "rm -r *": "deny",
      "rm * /": "deny",
      "mv * ../*": "deny",
      "chmod -R*": "deny",
      "chown -R*": "deny",
      "dd *": "deny",
      "> /dev/*": "deny",
      "sudo *": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "docker rm*": "ask",
      "docker rmi*": "ask",
      "kubectl delete*": "ask",
      "terraform destroy*": "deny",
      "terraform apply*": "ask",
      "helm delete*": "ask",
      "npm publish*": "deny",
      "pnpm publish*": "deny"
    },
    "edit": {
      "*": "ask",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/kubeconfig": "deny",
      "**/.kube/config": "deny",
      "**/terraform.tfstate": "deny",
      "**/.terraform/*": "deny",
      ".github/workflows/*": "ask",
      "Makefile": "ask",
      "Taskfile.yml": "ask"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "**/.env": "deny",
      "**/kubeconfig": "deny",
      "**/.kube/config": "deny",
      "**/terraform.tfstate": "deny"
    },
    "skill": {
      "chezmoi-expert": "allow"
    }
  }
}
